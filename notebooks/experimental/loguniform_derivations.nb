Notebook[{

Cell[CellGroupData[{
Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Parameters", ":", 
    RowBox[{"0", "<", "a", "<", "b"}]}], "*)"}], 
  RowBox[{
   RowBox[{"Clear", "[", 
    RowBox[{"a", ",", "b", ",", "s", ",", "x"}], "]"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"assumptions", "=", 
     RowBox[{"0", "<", "a", "<", "b"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   
   RowBox[{"(*", 
    RowBox[{"Log", "-", 
     RowBox[{"uniform", " ", "PDF"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"pdf", "[", "x_", "]"}], ":=", 
     RowBox[{"1", "/", 
      RowBox[{"(", 
       RowBox[{"x", " ", 
        RowBox[{"Log", "[", 
         RowBox[{"b", "/", "a"}], "]"}]}], ")"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Laplace", " ", "transform"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"L", "[", "s_", "]"}], ":=", 
     RowBox[{"Integrate", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Exp", "[", 
         RowBox[{
          RowBox[{"-", "s"}], " ", "x"}], "]"}], " ", 
        RowBox[{"pdf", "[", "x", "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "a", ",", "b"}], "}"}], ",", 
       RowBox[{"Assumptions", "->", "assumptions"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Display", " ", "the", " ", "transform"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{"laplaceResult", "=", 
    RowBox[{"FullSimplify", "[", 
     RowBox[{
      RowBox[{"L", "[", "s", "]"}], ",", "assumptions"}], "]"}]}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "Integrate", " ", "the", " ", "Laplace", " ", "transform", " ", "from", 
     " ", "0", " ", "to", " ", "Infinity"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"integratedLT", "=", 
    RowBox[{"FullSimplify", "[", 
     RowBox[{
      RowBox[{"Integrate", "[", 
       RowBox[{
        RowBox[{"L", "[", "s", "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"s", ",", "0", ",", "Infinity"}], "}"}], ",", 
        RowBox[{"Assumptions", "->", "assumptions"}]}], "]"}], ",", 
      "assumptions"}], "]"}]}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Expected", " ", "reciprocal", " ", 
     RowBox[{"E", "[", 
      RowBox[{"1", "/", "X"}], "]"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"expectedInverse", "=", 
    RowBox[{"FullSimplify", "[", 
     RowBox[{
      RowBox[{"Integrate", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "/", "x"}], ")"}], " ", 
         RowBox[{"pdf", "[", "x", "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"x", ",", "a", ",", "b"}], "}"}], ",", 
        RowBox[{"Assumptions", "->", "assumptions"}]}], "]"}], ",", 
      "assumptions"}], "]"}]}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Verify", " ", "equality"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"verification", "=", 
    RowBox[{"FullSimplify", "[", 
     RowBox[{
      RowBox[{"integratedLT", "==", "expectedInverse"}], ",", "assumptions"}],
      "]"}]}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Optional", ":", 
     RowBox[{"numerical", " ", "test"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"params", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"a", "->", "2"}], ",", 
       RowBox[{"b", "->", "10"}]}], "}"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"N", "[", 
    RowBox[{
     RowBox[{"laplaceResult", "/.", " ", "params"}], "/.", " ", 
     RowBox[{"s", "->", "1"}]}], "]"}], "\n", 
   RowBox[{"N", "[", 
    RowBox[{"integratedLT", "/.", " ", "params"}], "]"}], "\n", 
   RowBox[{"N", "[", 
    RowBox[{"expectedInverse", "/.", " ", "params"}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.98705264972447*^9, 3.987052649726384*^9}},
 CellLabel->
  "In[212]:=",ExpressionUUID->"38f8938a-3641-4f03-9228-b9f8bff8bdef"],

Cell[BoxData[
 FractionBox[
  RowBox[{
   RowBox[{"-", 
    RowBox[{"ExpIntegralEi", "[", 
     RowBox[{
      RowBox[{"-", "a"}], " ", "s"}], "]"}]}], "+", 
   RowBox[{"ExpIntegralEi", "[", 
    RowBox[{
     RowBox[{"-", "b"}], " ", "s"}], "]"}]}], 
  RowBox[{"Log", "[", 
   FractionBox["b", "a"], "]"}]]], "Output",
 CellChangeTimes->{3.987052651336803*^9},
 CellLabel->
  "Out[216]=",ExpressionUUID->"9365a704-60bc-4c11-b97d-955bec3f6202"],

Cell[BoxData[
 FractionBox[
  RowBox[{"a", "-", "b"}], 
  RowBox[{
   RowBox[{"a", " ", "b", " ", 
    RowBox[{"Log", "[", "a", "]"}]}], "-", 
   RowBox[{"a", " ", "b", " ", 
    RowBox[{"Log", "[", "b", "]"}]}]}]]], "Output",
 CellChangeTimes->{3.987052652949909*^9},
 CellLabel->
  "Out[217]=",ExpressionUUID->"74b39960-4642-475c-a959-9c8fba24be34"],

Cell[BoxData[
 FractionBox[
  RowBox[{
   FractionBox["1", "a"], "-", 
   FractionBox["1", "b"]}], 
  RowBox[{"Log", "[", 
   FractionBox["b", "a"], "]"}]]], "Output",
 CellChangeTimes->{3.987052653091815*^9},
 CellLabel->
  "Out[218]=",ExpressionUUID->"f271c0bf-4a7a-411f-895d-a0f770f5b84b"],

Cell[BoxData["True"], "Output",
 CellChangeTimes->{3.987052653164899*^9},
 CellLabel->
