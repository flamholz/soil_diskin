Notebook[{

Cell[CellGroupData[{
Cell[BoxData[{
 RowBox[{
  RowBox[{"(", 
   RowBox[{
    RowBox[{"C14DATADIR", "=", "\"\<soil_diskin/data/14C_atm_annot.csv\>\""}],
     ";", "\n", 
    RowBox[{"C14DATA", "=", 
     RowBox[{"Import", "[", 
      RowBox[{"C14DATADIR", ",", 
       RowBox[{"\"\<HeaderLines\>\"", "\[Rule]", "1"}]}], "]"}]}], ";", "\n", 
    
    RowBox[{"C14DATA", "=", 
     RowBox[{"C14DATA", "\[LeftDoubleBracket]", 
      RowBox[{"All", ",", 
       RowBox[{"{", 
        RowBox[{"4", ",", "5"}], "}"}]}], "\[RightDoubleBracket]"}]}], ";", 
    "\n", 
    RowBox[{"MeanR", "=", "10"}], ";", "\n", 
    RowBox[{"atm14C1", "=", 
     RowBox[{"Interpolation", "[", 
      RowBox[{"C14DATA", ",", 
       RowBox[{"InterpolationOrder", "\[Rule]", "0"}], ",", 
       RowBox[{"\"\<ExtrapolationHandler\>\"", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{"MeanR", "&"}], "}"}]}]}], "]"}]}], ";", "\n", 
    RowBox[{"atm14C2", "=", 
     RowBox[{"Interpolation", "[", 
      RowBox[{"C14DATA", ",", 
       RowBox[{"InterpolationOrder", "\[Rule]", "0"}], ",", 
       RowBox[{"\"\<ExtrapolationHandler\>\"", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{"0", "&"}], "}"}]}]}], "]"}]}], ";", "\n", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"LognormalRadiocarbon", "[", 
      RowBox[{"tau_", ",", "age_", ",", " ", "atm_"}], "]"}], ":=", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"sig", "=", 
        SqrtBox[
         RowBox[{"Log", "[", 
          FractionBox["age", "tau"], "]"}]]}], ";", 
       RowBox[{"mu", "=", 
        RowBox[{"-", 
         RowBox[{"Log", "[", 
          SqrtBox[
           FractionBox[
            SuperscriptBox["tau", "3"], "age"]], "]"}]}]}], ";", 
       RowBox[{"r", "=", 
        RowBox[{"NIntegrate", "[", 
         RowBox[{
          FractionBox[
           RowBox[{
            RowBox[{"atm", "[", "a", "]"}], " ", 
            RowBox[{"Exp", "[", 
             RowBox[{"-", 
              FractionBox["a", "8267"]}], "]"}], " ", 
            RowBox[{"PDF", "[", 
             RowBox[{
              RowBox[{"LogNormalDistribution", "[", 
               RowBox[{"mu", ",", "sig"}], "]"}], ",", "x"}], "]"}], " ", 
            RowBox[{"Exp", "[", 
             RowBox[{
              RowBox[{"-", "x"}], " ", "a"}], "]"}]}], 
           RowBox[{"Exp", "[", 
            RowBox[{
             RowBox[{"-", "mu"}], "+", 
             FractionBox[
              SuperscriptBox["sig", "2"], "2"]}], "]"}]], ",", 
          RowBox[{"{", 
           RowBox[{"x", ",", "0", ",", "\[Infinity]"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"a", ",", "0", ",", "\[Infinity]"}], "}"}], ",", 
          RowBox[{"PrecisionGoal", "\[Rule]", "3"}]}], "]"}]}], ";", "r"}], 
      ")"}]}], ";"}], ")"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"LognormalRadiocarbon", "[", 
  RowBox[{"13", ",", "10000", ",", "atm14C1"}], "]"}], "\n", 
 RowBox[{"LognormalRadiocarbon", "[", 
  RowBox[{"13", ",", "10000", ",", "atm14C2"}], 
  "]"}], "\[IndentingNewLine]"}], "Input",
 CellChangeTimes->{{3.986948603241254*^9, 3.986948687413063*^9}},
 CellLabel->
  "In[163]:=",ExpressionUUID->"d737061b-62a0-4477-97db-56a4d31a5e82"],

Cell[BoxData[
 TemplateBox[{
  "NIntegrate", "slwcon", 
   "\"Numerical integration converging too slowly; suspect one of the \
following: singularity, value of the integration is 0, highly oscillatory \
integrand, or WorkingPrecision too small.\"", 2, 164, 54, 
   24275313714889345370, "Local"},
