      RowBox[{"C14DATA", ",", " ", 
       RowBox[{"InterpolationOrder", " ", "->", " ", "0"}], ",", " ", "\n", 
       "   ", 
       RowBox[{"\"\<ExtrapolationHandler\>\"", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"(", 
          RowBox[{"MeanR", " ", "&"}], ")"}], "}"}]}]}], "]"}]}], ";"}], "\n",
    "\n", 
