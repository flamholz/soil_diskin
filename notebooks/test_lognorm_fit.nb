      RowBox[{"C14DATADIR", ",", " ", 
       RowBox[{"\"\<HeaderLines\>\"", " ", "->", " ", "1"}]}], "]"}]}], ";"}],
    "\n", 
   RowBox[{
    RowBox[{"C14DATA", " ", "=", " ", 
     RowBox[{"C14DATA", "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", " ", 
        RowBox[{"{", 
