Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Clear", " ", "symbols"}], "*)"}], 
  RowBox[{
   RowBox[{"Clear", "[", "\"\<Global`*\>\"", "]"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", "Assumptions", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"$Assumptions", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"t", ">=", "0"}], ",", 
       RowBox[{"tmin", ">", "0"}], ",", 
       RowBox[{"tmax", ">", "0"}], ",", 
       RowBox[{"a", "\[Element]", "Reals"}]}], "}"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "Define", " ", "the", " ", "differential", " ", "equation", " ", "for", 
     " ", "the", " ", "decreasing", " ", "survival", " ", "function"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ode", "=", 
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{"Log", "[", 
         RowBox[{"s", "[", "t", "]"}], "]"}], ",", "t"}], "]"}], "==", 
      RowBox[{"-", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"\[Alpha]", "/", 
          RowBox[{"(", 
           RowBox[{"t", "+", "tmin"}], ")"}]}], "+", 
         RowBox[{"1", "/", "tmax"}]}], ")"}]}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Solve", " ", "the", " ", "ODE"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"solGeneral", "=", 
     RowBox[{"DSolveValue", "[", 
      RowBox[{"ode", ",", "s", ",", "t"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Impose", " ", "s", 
      RowBox[{"(", "0", ")"}]}], "=", "1"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"solWithIC", "=", 
     RowBox[{
      RowBox[{"DSolveValue", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"ode", ",", 
          RowBox[{
           RowBox[{"s", "[", "0", "]"}], "==", "1"}]}], "}"}], ",", "s", ",", 
        "t"}], "]"}], "//", "FullSimplify"}]}], " ", ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Define", " ", "s", 
     RowBox[{"(", "t", ")"}], " ", "explicitly"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"surv", "[", "t_", "]"}], ":=", 
    RowBox[{"solWithIC", "[", "t", "]"}]}], "\n", 
   RowBox[{"surv", "[", "t", "]"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Compute", " ", "the", " ", "turnover"}], " ", "-", " ", 
     RowBox[{
     "the", " ", "integral", " ", "of", " ", "s", " ", "from", " ", "0", " ", 
      "to", " ", "Infinity"}]}], "*)"}], "\n", 
   RowBox[{"T", "=", 
    RowBox[{
     RowBox[{"Integrate", "[", 
      RowBox[{
       RowBox[{"surv", "[", "t", "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "0", ",", "Infinity"}], "}"}], ",", 
       RowBox[{"Assumptions", "->", "$Assumptions"}]}], "]"}], "//", 
     "FullSimplify"}]}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"pA", "[", "t_", "]"}], " ", ":=", " ", 
    RowBox[{
     RowBox[{"surv", "[", "t", "]"}], " ", "/", " ", "T"}]}], 
   "\[IndentingNewLine]", 
   RowBox[{"pA", "[", "t", "]"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{"pA", "[", "t", "]"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"t", ",", "0", ",", " ", "a"}], "}"}]}], "]"}], " ", "//", " ",
     "FullSimplify"}]}]}]], "Input",
