  RowBox[{
   RowBox[{
    RowBox[{
    "csvFile", "=", 
     "\"\<git/soil_diskin/results/03_calibrate_models/03b_lognormal_\
predictions_calcurve.csv\>\""}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"data", "=", 
     RowBox[{"Import", "[", 
      RowBox[{"csvFile", ",", "\"\<Dataset\>\"", ",", "  ", 
       RowBox[{"HeaderLines", " ", "->", " ", "1"}]}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Convert", " ", "to", " ", "normal", " ", "list", " ", "of", " ", 
     "associations"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"dataList", "=", 
     RowBox[{"Normal", "[", "data", "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "C14DATADIR", " ", "=", " ", 
     "\"\<git/soil_diskin/data/14C_atm_annot.csv\>\""}], ";"}], "\n", 
   RowBox[{
    RowBox[{"C14DATA", " ", "=", " ", 
     RowBox[{"Import", "[", 
      RowBox[{"C14DATADIR", ",", " ", 
       RowBox[{"\"\<HeaderLines\>\"", " ", "->", " ", "1"}]}], "]"}]}], ";"}],
    "\n", 
   RowBox[{
    RowBox[{"C14DATA", " ", "=", " ", 
     RowBox[{"C14DATA", "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", " ", 
        RowBox[{"{", 
         RowBox[{"4", ",", " ", "5"}], "}"}]}], "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Interpolate", " ", "the", " ", "14", "C", " ", "data"}], ",", 
     " ", 
     RowBox[{
     "use", " ", "the", " ", "mean", " ", "ratio", " ", "for", " ", 
      "extrapolation"}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"MeanR", " ", "=", " ", 
     RowBox[{"Last", "[", 
      RowBox[{"Mean", "[", 
       RowBox[{"C14DATA", "[", 
        RowBox[{"[", 
         RowBox[{
          RowBox[{"-", "50000"}], " ", ";;"}], "]"}], "]"}], "]"}], "]"}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"atm14C", " ", "=", " ", "\n", "  ", 
     RowBox[{"Interpolation", "[", 
      RowBox[{"C14DATA", ",", " ", 
       RowBox[{"InterpolationOrder", " ", "->", " ", "0"}], ",", " ", "\n", 
       "   ", 
       RowBox[{"\"\<ExtrapolationHandler\>\"", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"(", 
          RowBox[{"MeanR", " ", "&"}], ")"}], "}"}]}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
      "===", "===", "===", "=="}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"2.", " ", "Extract", " ", "inputs"}], "*)"}], "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
      "===", "===", "===", "=="}], "*)"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"taus", "=", 
     RowBox[{"dataList", "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", " ", "\"\<turnover\>\""}], "]"}], "]"}]}], ";"}], 
   "\n", 
   RowBox[{
    RowBox[{"ages", "=", 
     RowBox[{"dataList", "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", "\"\<pred\>\""}], "]"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"LognormalRadiocarbon", "[", 
     RowBox[{"tau_", ",", " ", "age_"}], "]"}], " ", ":=", " ", 
    RowBox[{"(", "\n", "  ", 
     RowBox[{
      RowBox[{"sig", " ", "=", " ", 
       RowBox[{"Sqrt", "[", 
        RowBox[{"Log", "[", 
         RowBox[{"age", "/", "tau"}], "]"}], "]"}]}], ";", "\n", "  ", 
      RowBox[{"mu", " ", "=", " ", 
       RowBox[{"-", 
        RowBox[{"Log", "[", 
         RowBox[{"Sqrt", "[", 
          RowBox[{
           RowBox[{"tau", "^", "3"}], "/", "age"}], "]"}], "]"}]}]}], ";", 
      "\n", "  ", 
      RowBox[{"r", " ", "=", " ", 
       RowBox[{"NIntegrate", "[", " ", "\n", "    ", 
        RowBox[{
         RowBox[{
          RowBox[{"atm14C", "[", "a", "]"}], "*", 
          RowBox[{"Exp", "[", 
           RowBox[{
            RowBox[{"-", "a"}], "/", "8267"}], "]"}], "*", " ", 
          RowBox[{"PDF", "[", 
           RowBox[{
            RowBox[{"LogNormalDistribution", "[", 
             RowBox[{"mu", ",", " ", "sig"}], "]"}], ",", " ", "x"}], "]"}], 
          " ", "*", " ", "\n", "     ", 
          RowBox[{
           RowBox[{"Exp", "[", 
            RowBox[{
             RowBox[{"-", "x"}], "*", "a"}], "]"}], " ", "/", " ", 
           RowBox[{"Exp", "[", 
            RowBox[{
             RowBox[{"-", "mu"}], " ", "+", " ", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"sig", "^", "2"}], ")"}], "/", "2"}]}], "]"}]}]}], ",",
          " ", 
         RowBox[{"{", 
          RowBox[{"x", ",", " ", "0", ",", " ", "Infinity"}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"a", ",", " ", "0", ",", " ", "\n", "     ", "Infinity"}], 
          "}"}], ",", " ", 
         RowBox[{"PrecisionGoal", " ", "->", " ", "3"}]}], "]"}]}], ";", "\n",
       "  ", "r"}], "\n", "  ", ")"}]}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
      "===", "===", "===", "=="}], "*)"}], 
   RowBox[{"(*", 
    RowBox[{
    "3.", " ", "Ensure", " ", "function", " ", "is", " ", "available"}], 
    "*)"}], 
   RowBox[{"(*", 
    RowBox[{"(", 
     RowBox[{
     "Assumes", " ", "you", " ", "already", " ", "ran", " ", "your", " ", 
      "WLS", " ", "setup"}], ")"}], "*)"}], 
   RowBox[{"(*", " ", 
    RowBox[{
    "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
      "===", "===", "===", "=="}], "*)"}], 
   RowBox[{"(*", 
    RowBox[{"If", " ", "running", " ", "in", " ", "parallel"}], "*)"}], 
   RowBox[{
    RowBox[{"LaunchKernels", "[", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"DistributeDefinitions", "[", 
     RowBox[{"LognormalRadiocarbon", ",", "atm14C"}], "]"}], ";"}], "\n", 
   "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
      "===", "===", "===", "=="}], "*)"}], "\n", 
   RowBox[{"(*", 
    RowBox[{"4.", " ", "Compute", " ", "fm", " ", "predictions"}], "*)"}], 
   "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
      "===", "===", "===", "=="}], "*)"}], "\n", "\n", 
   RowBox[{
    RowBox[{"fmPred", "=", 
     RowBox[{"ParallelMap", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Quiet", "[", 
         RowBox[{"LognormalRadiocarbon", "[", 
          RowBox[{"#1", ",", "#2"}], "]"}], "]"}], "&"}], ",", 
       RowBox[{"Transpose", "[", 
        RowBox[{"{", 
         RowBox[{"taus", ",", "ages"}], "}"}], "]"}]}], "]"}]}], ";"}], "\n", 
   "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
      "===", "===", "===", "=="}], "*)"}], "\n", 
   RowBox[{"(*", 
    RowBox[{
    "5.", " ", "Attach", " ", "results", " ", "back", " ", "to", " ", 
     "dataset"}], "*)"}], "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
      "===", "===", "===", "=="}], "*)"}], "\n", "\n", 
   RowBox[{
    RowBox[{"resultData", "=", 
     RowBox[{"MapThread", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Append", "[", 
         RowBox[{"#1", ",", 
          RowBox[{"\"\<fm_pred\>\"", "->", "#2"}]}], "]"}], "&"}], ",", 
       RowBox[{"{", 
        RowBox[{"dataList", ",", "fmPred"}], "}"}]}], "]"}]}], ";"}], "\n", 
   "\n", 
   RowBox[{"(*", 
    RowBox[{"Convert", " ", "back", " ", "to", " ", "Dataset"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"resultDataset", "=", 
     RowBox[{"Dataset", "[", "resultData", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
      "===", "===", "===", "=="}], "*)"}], "\n", 
   RowBox[{"(*", 
    RowBox[{"6.", " ", "Export"}], "*)"}], "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
      "===", "===", "===", "=="}], "*)"}], "\n", "\n", 
   RowBox[{
    RowBox[{"Export", "[", 
     RowBox[{"\"\<predicted_fm.csv\>\"", ",", "resultDataset"}], "]"}], 
    ";"}]}]}]], "Input",
