    RowBox[{"Print", "[", 
     RowBox[{"Style", "[", 
      RowBox[{"\"\<Step 1: Evaluate \[Integral]\:2080^\[Infinity] \[Tau] \
e^(-k\[Tau]) d\[Tau] using integration by parts\>\"", ",", "Bold", ",", 
       "12"}], "]"}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<\[Integral]\:2080^\[Infinity] \[Tau] e^(-k\[Tau]) d\[Tau] = \
\>\"", ",", "innerIntegral"}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Step", " ", "2"}], ":", 
     RowBox[{"Compute", " ", "the", " ", "double", " ", "integral"}]}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"Style", "[", 
      RowBox[{"\"\<Step 3: Integrate over k\>\"", ",", "Bold", ",", "12"}], 
      "]"}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<\[Integral]\:2080^\[Infinity] p(k)/k\.b2 dk = \>\"", ",", 
      "outerIntegral"}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Step", " ", "4"}], ":", 
     RowBox[{"Divide", " ", "by", " ", "T"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"Style", "[", 
      RowBox[{
       RowBox[{"\"\<Step 4: Divide by T = \>\"", "<>", 
        RowBox[{"ToString", "[", 
         RowBox[{"TraditionalForm", "[", "T", "]"}], "]"}]}], ",", "Bold", ",",
        "12"}], "]"}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<\[ABar] = (1/T) \[Integral]\:2080^\[Infinity] p(k)/k\.b2 dk \
= \>\"", ",", "meanAge"}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Step", " ", "5"}], ":", 
     RowBox[{"Verify", " ", "the", " ", "moment", " ", "ratio"}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"Style", "[", 
      RowBox[{"\"\<Step 5: Verify \[ABar] = \:27e8k^(-2)\:27e9 / \:27e8k^(-1)\
\:27e9\>\"", ",", "Bold", ",", "12"}], "]"}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<\:27e8k^(-2)\:27e9 = \>\"", ",", "moment2"}], "]"}], ";"}], 
   "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<\:27e8k^(-1)\:27e9 = \>\"", ",", "moment1"}], "]"}], ";"}], 
   "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<\:27e8k^(-2)\:27e9 / \:27e8k^(-1)\:27e9 = \>\"", ",", 
      "momentRatio"}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<\>\"", "]"}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Step", " ", "6"}], ":", 
     RowBox[{"Verify", " ", "closed", " ", "form"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"Style", "[", 
      RowBox[{"\"\<Step 6: Simplify to closed form\>\"", ",", "Bold", ",", 
       "12"}], "]"}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"closedForm", "=", 
     RowBox[{"Exp", "[", 
      RowBox[{
       RowBox[{"-", "\[Mu]"}], "+", 
       RowBox[{"3", "*", 
        RowBox[{
         RowBox[{"\[Sigma]", "^", "2"}], "/", "2"}]}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<\[ABar] = \>\"", ",", "meanAge"}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Expected: \>\"", ",", "closedForm"}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Are they equal? \>\"", ",", 
      RowBox[{"Simplify", "[", 
       RowBox[{"meanAge", "==", "closedForm"}], "]"}]}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<\>\"", "]"}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"Step", " ", "7"}], ":", 
      RowBox[{"Verify", " ", "the", " ", "relation", " ", "\[ABar]"}]}], "=", 
     
     RowBox[{"T", "\[CenterDot]", 
      RowBox[{"e", "^", 
       RowBox[{"(", "\[Sigma]\.b2", ")"}]}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"Style", "[", 
      RowBox[{"\"\<Step 7: Verify \[ABar] = T\[CenterDot]e^(\[Sigma]\.b2)\>\"",
        ",", "Bold", ",", "12"}], "]"}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"relation", "=", 
     RowBox[{"Simplify", "[", 
      RowBox[{"T", "*", 
       RowBox[{"Exp", "[", 
        RowBox[{"\[Sigma]", "^", "2"}], "]"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<T\[CenterDot]e^(\[Sigma]\.b2) = \>\"", ",", "relation"}], 
     "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<\[ABar] = \>\"", ",", "meanAge"}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Are they equal? \>\"", ",", 
      RowBox[{"Simplify", "[", 
       RowBox[{"meanAge", "==", "relation"}], "]"}]}], "]"}], 
    ";"}]}]}]], "Input",
