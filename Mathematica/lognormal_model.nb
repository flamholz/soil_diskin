Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"===", 
    RowBox[{"==", 
     RowBox[{
     "Symbolic", " ", "Derivation", " ", "of", " ", "Turnover", " ", "Time", " ",
       "T", " ", "for", " ", "the", " ", "lognormal", " ", "continuum", " ", 
      "model"}]}], "===", "=="}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Define", " ", "the", " ", "lognormal", " ", "PDF"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"pk", "[", 
      RowBox[{"k_", ",", "\[Mu]_", ",", "\[Sigma]_"}], "]"}], ":=", 
     RowBox[{"PDF", "[", 
      RowBox[{
       RowBox[{"LogNormalDistribution", "[", 
        RowBox[{"\[Mu]", ",", "\[Sigma]"}], "]"}], ",", "k"}], "]"}]}], ";"}],
    "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"T", " ", "=", 
     RowBox[{
      RowBox[{"\[Integral]", " ", 
       RowBox[{"s", 
        RowBox[{"(", "\[Tau]", ")"}], "d\[Tau]"}]}], " ", "=", " ", 
      RowBox[{
       RowBox[{"\[Integral]", 
        RowBox[{"\[Integral]", " ", 
         RowBox[{"p", 
          RowBox[{"(", "k", ")"}], " ", "exp", 
          RowBox[{"(", 
           RowBox[{"-", "kt"}], ")"}], " ", "dk", " ", "d\[Tau]"}]}]}], " ", "=",
        " ", 
       RowBox[{"\[Integral]", " ", 
        RowBox[{"p", 
         RowBox[{"(", "k", ")"}], " ", 
         RowBox[{"\[Integral]", " ", 
          RowBox[{"exp", 
           RowBox[{"(", 
            RowBox[{"-", "k\[Tau]"}], ")"}], " ", "d\[Tau]", " ", 
           "dk"}]}]}]}]}]}]}], " ", "*)"}], " ", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"innerIntegral", "=", 
     RowBox[{"Integrate", "[", 
      RowBox[{
       RowBox[{"Exp", "[", 
        RowBox[{
         RowBox[{"-", "k"}], "*", "\[Tau]"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"\[Tau]", ",", "0", ",", "\[Infinity]"}], "}"}], ",", 
       RowBox[{"Assumptions", "->", 
        RowBox[{"{", 
         RowBox[{"k", ">", "0"}], "}"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"outerIntegrand", " ", "=", " ", 
     RowBox[{"innerIntegral", "*", 
      RowBox[{"pk", "[", 
       RowBox[{"k", ",", "\[Mu]", ",", "\[Sigma]"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"T", "=", 
