   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<\[Integral]\:2080^\[Infinity] \[Tau] e^(-k\[Tau]) d\[Tau] = \
\>\"", ",", "innerIntegral"}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Step", " ", "2"}], ":", 
     RowBox[{"Compute", " ", "the", " ", "double", " ", "integral"}]}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"Style", "[", 
      RowBox[{"\"\<Step 3: Integrate over k\>\"", ",", "Bold", ",", "12"}], 
      "]"}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<\[Integral]\:2080^\[Infinity] p(k)/k\.b2 dk = \>\"", ",", 
      "outerIntegral"}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Step", " ", "4"}], ":", 
     RowBox[{"Divide", " ", "by", " ", "T"}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"Style", "[", 
      RowBox[{
       RowBox[{"\"\<Step 4: Divide by T = \>\"", "<>", 
        RowBox[{"ToString", "[", 
         RowBox[{"TraditionalForm", "[", "T", "]"}], "]"}]}], ",", "Bold", ",",
        "12"}], "]"}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<\[ABar] = (1/T) \[Integral]\:2080^\[Infinity] p(k)/k\.b2 dk \
= \>\"", ",", "meanAge"}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<\>\"", "]"}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Step", " ", "5"}], ":", 
     RowBox[{"Verify", " ", "the", " ", "moment", " ", "ratio"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"Style", "[", 
      RowBox[{"\"\<Step 5: Verify \[ABar] = \:27e8k^(-2)\:27e9 / \:27e8k^(-1)\
\:27e9\>\"", ",", "Bold", ",", "12"}], "]"}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<\:27e8k^(-2)\:27e9 = \>\"", ",", "moment2"}], "]"}], ";"}], 
   "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<\:27e8k^(-1)\:27e9 = \>\"", ",", "moment1"}], "]"}], ";"}], 
   "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<\:27e8k^(-2)\:27e9 / \:27e8k^(-1)\:27e9 = \>\"", ",", 
      "momentRatio"}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   "\n", 
   RowBox[{"(*", 
