   RowBox[{
    RowBox[{"Print", "[", "\"\<\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Mean", " ", "age"}], " ", "=", " ", 
     RowBox[{
      RowBox[{"\[Integral]", 
       RowBox[{"\[Tau]", " ", 
        SubscriptBox["p", "a"], 
        RowBox[{"(", "\[Tau]", ")"}], " ", "d\[Tau]"}]}], " ", "=", " ", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "/", "T"}], ")"}], 
        RowBox[{"\[Integral]", 
         RowBox[{"\[Tau]", " ", "s", 
          RowBox[{"(", "\[Tau]", ")"}], " ", "d\[Tau]"}]}]}], " ", "=", " ", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "/", "T"}], ")"}], 
        RowBox[{"\[Integral]", 
         RowBox[{"p", 
          RowBox[{"(", "k", ")"}], 
          RowBox[{"\[Integral]", 
           RowBox[{"\[Tau]", " ", "exp", 
            RowBox[{"(", 
             RowBox[{"-", "k\[Tau]"}], ")"}], " ", "dk", " ", 
            "d\[Tau]"}]}]}]}]}]}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
   " ", "\[IndentingNewLine]", 
