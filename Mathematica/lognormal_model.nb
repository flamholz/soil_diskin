      RowBox[{"outerIntegrand", ",", 
       RowBox[{"{", 
        RowBox[{"k", ",", "0", ",", "\[Infinity]"}], "}"}], ",", 
       RowBox[{"Assumptions", "->", 
        RowBox[{"\[Sigma]", ">", "0"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"meanAge", "=", 
