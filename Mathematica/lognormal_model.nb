     RowBox[{"Verify", " ", "closed", " ", "form"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"Style", "[", 
      RowBox[{"\"\<Step 6: Simplify to closed form\>\"", ",", "Bold", ",", 
       "12"}], "]"}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"closedForm", "=", 
     RowBox[{"Exp", "[", 
      RowBox[{
       RowBox[{"-", "\[Mu]"}], "+", 
       RowBox[{"3", "*", 
        RowBox[{
         RowBox[{"\[Sigma]", "^", "2"}], "/", "2"}]}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
